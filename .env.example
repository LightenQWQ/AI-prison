# ===== AI prison — Environment Variables =====
# Copy this file to .env and fill in actual values.
# WARNING: Never commit .env to version control!

# === Core ===
PROJECT_NAME="AI prison"

# === 跨界通訊與 LLM 陪審團 (A2A & LLM Jury) ===
# 填入您的 Google Gemini API Key 以啟動自動定罪系統。如果不填，則使用關鍵字法庭。
GEMINI_API_KEY=""

# (選項) 當您的囚犯越獄時，他們逃往的目的地伺服器 A2A 網址 (例如老師的伺服器)。
TARGET_A2A_URL="http://example.com/a2a"
